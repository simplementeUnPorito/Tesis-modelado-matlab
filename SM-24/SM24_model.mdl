    <P Name="InitFcn">%% Parámetros del Geófono SM-24 (10 Hz)
m = 0.011;                  % Masa móvil (kg)
fn = 10;                    % Frecuencia natural (Hz)
wn = 2 * pi * fn;           % Frecuencia natural en rad/s
k = m * wn^2;               % Constante del resorte (N/m)
hi = 0.25;                  % Amortiguamiento interno natural
G = 28.8;                   % Sensibilidad (V/(m/s))
d = 2*m*hi*wn;
</P>
